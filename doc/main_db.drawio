        <mxCell id="lZlPiMZXTP2hVzrFv9AQ-33" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;verticalAlign=top;" value="* Note that the actual API keys are never stored in the database. They are stored in the system keyring by nicknames. The databse maps aliases to nicknames and key_sign is the last 4 letters of the key for tracing spendings." vertex="1">
          <mxGeometry height="160" width="140" x="39" y="904" as="geometry" />
        </mxCell>
        <mxCell id="lZlPiMZXTP2hVzrFv9AQ-37" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;verticalAlign=top;" value="** details in outgoing msg are options of the preset, which can be different from those in preset table, because user can change options when sending prompt, or also user can change preset itself after sending the prompt." vertex="1">
          <mxGeometry height="160" width="140" x="200" y="904" as="geometry" />
        </mxCell>
        <mxCell id="lZlPiMZXTP2hVzrFv9AQ-38" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;align=center;verticalAlign=top;" value="*** If agent_id is zero, it means that this message was created by the user. A message coming from an agent will obviously have agent_id." vertex="1">
          <mxGeometry height="160" width="140" x="360" y="904" as="geometry" />
        </mxCell>
        <mxCell id="WUCZ_cMpY2I_qUcItM1T-1" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;.rno Sandbox Database&lt;/h1&gt;&lt;div&gt;Schema Version: 2&lt;/div&gt;&lt;p&gt;A database for storing presets and chat history. It needs to be backward compatible: the new versions of the application should be able to upgrade this database to the latest version without losing any data.&lt;/p&gt;" vertex="1">
          <mxGeometry height="120" width="290" x="260" y="30" as="geometry" />
        </mxCell>
        <mxCell id="L7148In-dE-eZ4DzWqva-20" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;align=center;verticalAlign=top;" value="**** Agent index is needed because each chat has an array of Agents, starting from 0, for Omnix whic is encompassing &quot;all messages&quot; of the chat." vertex="1">
          <mxGeometry height="160" width="140" x="520" y="904" as="geometry" />
        </mxCell>
